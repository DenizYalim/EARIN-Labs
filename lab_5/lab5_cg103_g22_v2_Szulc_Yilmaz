class Loss:
    def __init__(self, loss_function: callable, loss_function_derivative: callable) -> None:
        self.loss_function = loss_function
        self.loss_function_derivative = loss_function_derivative

    def loss(self, y_pred: np.ndarray, y_true: np.ndarray) -> float:
        return self.loss_function(y_pred, y_true)

    def loss_derivative(self, y_pred: np.ndarray, y_true: np.ndarray) -> np.ndarray:
        return self.loss_function_derivative(y_pred, y_true)


class Network:
    def __init__(self, layers: List[Layer], learning_rate: float) -> None:
        self.layers = layers
        self.learning_rate = learning_rate

    # Store the Loss object. Set learning_rate on all layers.
    def compile(self, loss_obj: Loss) -> None:
        self.loss = loss_obj
        for layer in self.layers:
            layer.learning_rate = self.learning_rate

    # Run forward propagation through all layers in sequence.
    def __call__(self, x: np.ndarray) -> np.ndarray:
        """Forward propagation of x through all layers"""
        for layer in self.layers:  # cool implementation
            x = layer.forward(x)
        return x

    # Train: forward → loss → backward through all layers in reverse. Return per-epoch loss list.
    def fit(self, x_train: np.ndarray, y_train: np.ndarray, epochs: int, learning_rate: float, verbose: int = 0) -> List[float]:
        # what is verbose?
        # update learning rate
        self.learning_rate = learning_rate
        for layer in self.layers:
            layer.learning_rate = learning_rate

        epoch_losses = []

        for epoch in range(epochs):
            total_loss = 0.0

            for i in range(x_train.shape[0]):
                x = x_train[i]
                y_true = y_train[i]

                # Forward pass
                y_pred = self(x)

                # Calculate loss
                loss_value = self.loss.loss(y_pred, y_true)
                total_loss += loss_value

                # Calculate derivative of loss
                error_derivative = self.loss.loss_derivative(y_pred, y_true)

                # Backward pass
                for layer in reversed(self.layers):
                    error_derivative = layer.backward(error_derivative)

            average_loss = total_loss / x_train.shape[0]
            epoch_losses.append(average_loss)

        return epoch_losses


