class Loss:
    def __init__(self, loss_function: callable, loss_function_derivative: callable) -> None:
        self.loss_function = loss_function
        self.loss_function_derivative = loss_function_derivative

    def loss(self, y_pred: np.ndarray, y_true: np.ndarray) -> float:
        return self.loss_function(y_pred, y_true)

    def loss_derivative(self, y_pred: np.ndarray, y_true: np.ndarray) -> np.ndarray:
        return self.loss_function_derivative(y_pred, y_true)


class Tanh(Layer):
    def forward(self, x: np.ndarray) -> np.ndarray:
        self.input_cached = x
        self.output = np.tanh(x)
        return self.output

    def backward(self, output_error_derivative) -> np.ndarray:
        return output_error_derivative * (1 - np.tanh(self.input_cached) ** 2)


class Sigmoid(Layer):
    def forward(self, x: np.ndarray) -> np.ndarray:
        self.input_cached = x
        x = np.clip(x, -500, 500)
        self.output = 1 / (1 + np.exp(-x))
        return self.output

    def backward(self, output_error_derivative) -> np.ndarray:
        return output_error_derivative * self.output * (1 - self.output)


class ReLU(Layer):
    def forward(self, x: np.ndarray) -> np.ndarray:
        self.input_cached = x
        self.output = np.maximum(0, x)
        return self.output

    def backward(self, output_error_derivative) -> np.ndarray:
        derivative = np.where(self.input_cached > 0, 1, 0)
        return output_error_derivative * derivative


class LeakyReLU(Layer):
    def __init__(self, alpha: float = 0.01) -> None:
        super().__init__()
        self.alpha = alpha

    def forward(self, x: np.ndarray) -> np.ndarray:
        self.input_cached = x
        self.output = np.where(x > 0, x, self.alpha * x)
        return self.output

    def backward(self, output_error_derivative) -> np.ndarray:
        derivative = np.where(self.input_cached > 0, 1, self.alpha)
        return output_error_derivative * derivative


class Network:
    def __init__(self, layers: List[Layer], learning_rate: float) -> None:
        self.layers = layers
        self.learning_rate = learning_rate

    # Store the Loss object. Set learning_rate on all layers.
    def compile(self, loss_obj: Loss) -> None:
        self.loss = loss_obj
        for layer in self.layers:
            layer.learning_rate = self.learning_rate

    # Run forward propagation through all layers in sequence.
    def __call__(self, x: np.ndarray) -> np.ndarray:
        """Forward propagation of x through all layers"""
        for layer in self.layers:  # cool implementation
            x = layer.forward(x)
        return x

    # Train: forward → loss → backward through all layers in reverse. Return per-epoch loss list.
    def fit(self, x_train: np.ndarray, y_train: np.ndarray, epochs: int, learning_rate: float, verbose: int = 0) -> List[float]:
        # what is verbose?
        # update learning rate
        self.learning_rate = learning_rate
        for layer in self.layers:
            layer.learning_rate = learning_rate

        epoch_losses = []

        for epoch in range(epochs):
            total_loss = 0.0

            for i in range(x_train.shape[0]):
                x = x_train[i]
                y_true = y_train[i]

                # Forward pass
                y_pred = self(x)

                # Calculate loss
                loss_value = self.loss.loss(y_pred, y_true)
                total_loss += loss_value

                # Calculate derivative of loss
                error_derivative = self.loss.loss_derivative(y_pred, y_true)

                # Backward pass
                for layer in reversed(self.layers):
                    error_derivative = layer.backward(error_derivative)

            average_loss = total_loss / x_train.shape[0]
            epoch_losses.append(average_loss)

        return epoch_losses


# loss MSE 	1 n ∑ ( y p − y t ) 2   f'=	2 n ( y p − y t )
def mse_loss(y_pred: np.ndarray, y_true: np.ndarray) -> float:
    return np.mean((y_pred - y_true) ** 2)


# loss funciton taken from group D
def mse_loss_derivative(y_pred: np.ndarray, y_true: np.ndarray) -> np.ndarray:
    return 2 * (y_pred - y_true) / y_true.shape[0]


from sklearn.datasets import fetch_openml
from sklearn.model_selection import train_test_split

if __name__ == "__main__":
    print("Loading Fashion-MNIST dataset...")
    dataset = fetch_openml("mnist_784", version=1, as_frame=False)

    X = dataset.data / 255.0
    y = dataset.target.astype(int)
    y_onehot = np.eye(10)[y]

    X_train, X_test, y_train, y_test = train_test_split(X, y_onehot, test_size=0.2, random_state=0)

    # Optional: Minibatching, explained in the source given; gives faster; Stochastic Gradient Descent
    X_train = X_train[:5000]
    y_train = y_train[:5000]
    X_test = X_test[:1000]
    y_test = y_test[:1000]

    print("Creating network object")

    network = Network(
        layers=[FullyConnected(input_size=784, output_size=64), ReLU(), FullyConnected(input_size=64, output_size=10)],
        learning_rate=0.01,
    )

    loss_obj = Loss(mse_loss, mse_loss_derivative)

    network.compile(loss_obj)

    print("Training started...")
    timer = Timer("Training timer")
    timer()
    losses = network.fit(X_train, y_train, epochs=5, learning_rate=0.01, verbose=1)

    print("Training finished.")
    timer()
    print("Loss history:", losses)

    print("Testing started...")

    correct = 0
    # testing
    for i in range(X_test.shape[0]):
        x = X_test[i]
        y_true = y_test[i]

        y_pred = network(x)

        predicted_class = np.argmax(y_pred)
        true_class = np.argmax(y_true)

        if predicted_class == true_class:
            correct += 1

    accuracy = correct / X_test.shape[0]

    print("Testing finished.")
    print("Test accuracy:", accuracy)
